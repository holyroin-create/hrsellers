---
const year = new Date().getFullYear();
---
<footer class="ftr">
  <div class="container">
    <div class="ftr-top">
      <div class="ftr-brand">
        <a href="/" class="fbrand notranslate" translate="no">
          <span class="fbrand-mark" aria-hidden="true">
            <svg viewBox="0 0 40 40">
              <defs><linearGradient id="hrm-f" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#12A083"/><stop offset="1" stop-color="#0A5B4B"/></linearGradient></defs>
              <rect width="40" height="40" rx="11" fill="url(#hrm-f)"/>
              <text x="20" y="20.5" text-anchor="middle" dominant-baseline="middle" font-family="'Bricolage Grotesque','Arial Black',sans-serif" font-weight="800" font-size="16" fill="#ffffff" letter-spacing="-0.5">HR</text>
              <path d="M11.5 30c3-.6 5-3.2 8-3.2 2 0 3.4 1.3 5 .2" stroke="#FF8A6B" stroke-width="2.1" fill="none" stroke-linecap="round"/>
              <path d="M25.6 27.4l2.4-.6-.6 2.4" stroke="#FF8A6B" stroke-width="2.1" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <span class="fbrand-name"><span class="hr">HR</span>Sellers</span>
        </a>
        <p class="ftr-tag">Tools, guides, and honest reviews for sellers on every major marketplace.</p>
        <div class="socials" aria-label="Social links">
          <a href="#" aria-label="X / Twitter"><svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"/></svg></a>
          <a href="#" aria-label="YouTube"><svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8ZM9.6 15.6V8.4l6.2 3.6-6.2 3.6Z"/></svg></a>
          <a href="#" aria-label="LinkedIn"><svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13ZM7.12 20.45H3.56V9h3.56v11.45ZM22.22 0H1.77C.8 0 0 .78 0 1.74v20.52C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.74V1.74C24 .78 23.2 0 22.22 0Z"/></svg></a>
        </div>
      </div>

      <div class="ftr-cols">
        <div class="ftr-col">
          <h4>Content</h4>
          <a href="/guides/">Guides</a>
          <a href="/reviews/">Tool Reviews</a>
          <a href="/marketplaces/">Marketplaces</a>
          <a href="/resources/">Resources</a>
        </div>
        <div class="ftr-col">
          <h4>Marketplaces</h4>
          <a href="/marketplaces/amazon/">Amazon</a>
          <a href="/marketplaces/ebay/">eBay</a>
          <a href="/marketplaces/shopify/">Shopify</a>
          <a href="/marketplaces/etsy/">Etsy</a>
          <a href="/marketplaces/walmart/">Walmart</a>
          <a href="/marketplaces/aliexpress/">AliExpress</a>
          <a href="/marketplaces/tiktok-shop/">TikTok Shop</a>
        </div>
        <div class="ftr-col">
          <h4>Company</h4>
          <a href="/about/">About</a>
          <a href="/contact/">Contact</a>
          <a href="/editorial-standards/">Editorial Standards</a>
          <a href="/#newsletter">Newsletter</a>
        </div>
        <div class="ftr-col">
          <h4>Legal</h4>
          <a href="/privacy/">Privacy Policy</a>
          <a href="/terms/">Terms of Service</a>
          <a href="/affiliate-disclosure/">Affiliate Disclosure</a>
          <a href="/cookie-policy/">Cookie Policy</a>
        </div>
      </div>
    </div>

    <div class="ftr-bottom">
      <p class="ftr-disc">As an Amazon Associate and affiliate partner, HRSellers earns from qualifying purchases and referrals at no additional cost to you. © {year} HRSellers. All recommendations are based on independent research and real operational use.</p>
      <div class="ftr-bottom-right">
        <div class="ftr-lang">
          <svg viewBox="0 0 20 20" width="16" height="16"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M2 10h16M10 2c2.5 2.4 2.5 13.6 0 16M10 2c-2.5 2.4-2.5 13.6 0 16" stroke="currentColor" stroke-width="1.2" fill="none"/></svg>
          English
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .ftr { background: var(--bg-ink); color: #C3CCD6; padding: 64px 0 32px; margin-top: 96px; }
  .ftr-top { display: grid; grid-template-columns: 1.2fr 2.4fr; gap: 56px; padding-bottom: 44px; border-bottom: 1px solid rgba(255,255,255,.1); }
  .fbrand { display: flex; align-items: center; gap: 11px; }
  .fbrand-mark svg { width: 38px; height: 38px; border-radius: 11px; }
  .fbrand-name { font-family: var(--display); font-weight: 800; font-size: 1.3rem; color: #fff; letter-spacing: -0.03em; }
  .fbrand-name .hr { color: #4FD0AE; }
  .ftr-tag { margin-top: 16px; font-size: 0.95rem; line-height: 1.6; color: #8B97A4; max-width: 32ch; }
  .socials { display: flex; gap: 10px; margin-top: 22px; }
  .socials a { width: 38px; height: 38px; border-radius: 10px; background: rgba(255,255,255,.07); display: grid; place-items: center; color: #C3CCD6; transition: background .15s, color .15s, transform .15s; }
  .socials a:hover { background: var(--brand); color: #fff; transform: translateY(-2px); }

  .ftr-cols { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; }
  .ftr-col h4 { font-family: var(--sans); font-size: 0.82rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: #fff; margin-bottom: 16px; }
  .ftr-col a { display: block; font-size: 0.92rem; color: #9CA8B4; padding: 5px 0; transition: color .14s; }
  .ftr-col a:hover { color: #fff; }

  .ftr-bottom { display: flex; justify-content: space-between; align-items: center; gap: 24px; padding-top: 28px; flex-wrap: wrap; }
  .ftr-disc { font-size: 0.8rem; line-height: 1.55; color: #74808C; max-width: 78ch; }
  .ftr-lang { display: inline-flex; align-items: center; gap: 7px; font-size: 0.85rem; color: #9CA8B4; padding: 7px 13px; border: 1px solid rgba(255,255,255,.12); border-radius: var(--r-sm); }

  @media (max-width: 860px) {
    .ftr-top { grid-template-columns: 1fr; gap: 40px; }
    .ftr-cols { grid-template-columns: repeat(2, 1fr); gap: 28px; }
  }
  @media (max-width: 720px) {
    .ftr-bottom { flex-direction: column; align-items: flex-start; }
  }
</style>
