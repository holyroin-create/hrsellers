---
// HRSellers header — logo monogram, full dropdown nav, language switcher.
---
<header class="hdr" id="top">
  <div class="container hdr-inner">
    <!-- Logo: HR monogram + fixed wordmark -->
    <a href="/" class="brand notranslate" translate="no" aria-label="HRSellers home">
      <span class="brand-mark" aria-hidden="true">
        <svg viewBox="0 0 40 40">
          <defs><linearGradient id="hrm-h" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#12A083"/><stop offset="1" stop-color="#0A5B4B"/></linearGradient></defs>
          <rect width="40" height="40" rx="11" fill="url(#hrm-h)"/>
          <text x="20" y="20.5" text-anchor="middle" dominant-baseline="middle" font-family="'Bricolage Grotesque','Arial Black',sans-serif" font-weight="800" font-size="16" fill="#ffffff" letter-spacing="-0.5">HR</text>
          <path d="M11.5 30c3-.6 5-3.2 8-3.2 2 0 3.4 1.3 5 .2" stroke="#FF8A6B" stroke-width="2.1" fill="none" stroke-linecap="round"/>
          <path d="M25.6 27.4l2.4-.6-.6 2.4" stroke="#FF8A6B" stroke-width="2.1" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
      <span class="brand-name"><span class="hr">HR</span>Sellers</span>
    </a>

    <!-- Primary nav — every item has a dropdown + chevron -->
    <nav class="nav" aria-label="Primary">
      <div class="nav-item">
        <a href="/" class="nav-link">Home <svg class="chev" viewBox="0 0 12 12"><path d="M3 4.5 6 7.5 9 4.5" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        <div class="dropdown">
          <a href="/#top">Overview</a>
          <a href="/#home-marketplaces">Marketplaces</a>
          <a href="/#home-guides">Featured guides</a>
          <a href="/#home-tools">Tool comparison</a>
          <a href="/#newsletter">Newsletter</a>
        </div>
      </div>

      <div class="nav-item">
        <button class="nav-link" aria-haspopup="true">Guides <svg class="chev" viewBox="0 0 12 12"><path d="M3 4.5 6 7.5 9 4.5" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
        <div class="dropdown">
          <a href="/guides/getting-started/">Getting Started</a>
          <a href="/guides/shipping-logistics/">Shipping &amp; Logistics</a>
          <a href="/guides/fees-reimbursements/">Fees &amp; Reimbursements</a>
          <a href="/guides/account-management/">Account Management</a>
          <a href="/guides/scaling/">Scaling Your Business</a>
          <a href="/guides/" class="dd-all">All Guides →</a>
        </div>
      </div>

      <div class="nav-item">
        <button class="nav-link" aria-haspopup="true">Tool Reviews <svg class="chev" viewBox="0 0 12 12"><path d="M3 4.5 6 7.5 9 4.5" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
        <div class="dropdown">
          <a href="/reviews/#research-tools">Research Tools</a>
          <a href="/reviews/#reimbursement-tools">Reimbursement Tools</a>
          <a href="/reviews/#repricing-tools">Repricing Tools</a>
          <a href="/reviews/#accounting-tax">Accounting &amp; Tax</a>
          <a href="/reviews/" class="dd-all">All Reviews →</a>
        </div>
      </div>

      <div class="nav-item">
        <button class="nav-link" aria-haspopup="true">Marketplaces <svg class="chev" viewBox="0 0 12 12"><path d="M3 4.5 6 7.5 9 4.5" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
        <div class="dropdown dropdown-wide notranslate" translate="no">
          <a href="/marketplaces/amazon/"><span class="mp-ico" style="background:#FF9900">a</span> Amazon</a>
          <a href="/marketplaces/ebay/"><span class="mp-ico" style="background:#E53238">e</span> eBay</a>
          <a href="/marketplaces/shopify/"><span class="mp-ico" style="background:#5E8E3E">S</span> Shopify</a>
          <a href="/marketplaces/etsy/"><span class="mp-ico" style="background:#F1641E">E</span> Etsy</a>
          <a href="/marketplaces/walmart/"><span class="mp-ico" style="background:#0071DC">W</span> Walmart</a>
          <a href="/marketplaces/aliexpress/"><span class="mp-ico" style="background:#E62E04">A</span> AliExpress</a>
          <a href="/marketplaces/tiktok-shop/"><span class="mp-ico" style="background:#111">T</span> TikTok Shop</a>
          <a href="/marketplaces/" class="dd-all">All Marketplaces →</a>
        </div>
      </div>

      <div class="nav-item">
        <a href="/resources/" class="nav-link">Resources <svg class="chev" viewBox="0 0 12 12"><path d="M3 4.5 6 7.5 9 4.5" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        <div class="dropdown">
          <a href="/resources/#research">Research &amp; Product Tools</a>
          <a href="/resources/#reimbursement">Reimbursement &amp; Refunds</a>
          <a href="/resources/#repricing">Repricing</a>
          <a href="/resources/#accounting">Accounting &amp; Tax</a>
          <a href="/resources/#operations">Inventory &amp; Operations</a>
          <a href="/resources/" class="dd-all">All Resources →</a>
        </div>
      </div>

      <div class="nav-item">
        <a href="/about/" class="nav-link">About <svg class="chev" viewBox="0 0 12 12"><path d="M3 4.5 6 7.5 9 4.5" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        <div class="dropdown">
          <a href="/about/">Our Story</a>
          <a href="/contact/">Contact</a>
          <a href="/editorial-standards/">Editorial Standards</a>
        </div>
      </div>
    </nav>

    <!-- Right utilities -->
    <div class="hdr-utils">
      <div class="nav-item lang">
        <button class="util-btn" aria-haspopup="true" aria-label="Select language">
          <svg viewBox="0 0 20 20" width="19" height="19"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.4" fill="none"/><path d="M2 10h16M10 2c2.5 2.4 2.5 13.6 0 16M10 2c-2.5 2.4-2.5 13.6 0 16" stroke="currentColor" stroke-width="1.2" fill="none"/></svg>
          <span class="lang-cur notranslate" translate="no">EN</span>
          <svg class="chev" viewBox="0 0 12 12"><path d="M3 4.5 6 7.5 9 4.5" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="dropdown dropdown-right notranslate" translate="no">
          <a href="#" onclick="hrSetLang('en','EN');return false;">English</a>
          <a href="#" onclick="hrSetLang('zh-CN','中文');return false;">中文 (Chinese)</a>
          <a href="#" onclick="hrSetLang('es','ES');return false;">Español</a>
          <a href="#" onclick="hrSetLang('ar','عربى');return false;">العربية</a>
          <a href="#" onclick="hrSetLang('pt','PT');return false;">Português</a>
          <a href="#" onclick="hrSetLang('tr','TR');return false;">Türkçe</a>
        </div>
      </div>
      <a href="/#newsletter" class="btn btn-accent cta-btn">Free Guide</a>
    </div>

    <!-- Mobile toggle -->
    <button class="burger" aria-label="Menu" onclick="document.body.classList.toggle('mnav-open')"><span></span><span></span><span></span></button>
  </div>

  <!-- Mobile menu -->
  <div class="mnav">
    <a href="/">Home</a>
    <a href="/guides/">Guides</a>
    <a href="/reviews/">Tool Reviews</a>
    <a href="/marketplaces/" class="notranslate" translate="no">Marketplaces</a>
    <a href="/resources/">Resources</a>
    <a href="/about/">About</a>
    <a href="/contact/">Contact</a>
    <a href="/#newsletter" class="mnav-cta">Free Guide</a>
  </div>
</header>

<!-- Hidden Google Translate element — loaded ONLY when a language is selected (keeps pages fast) -->
<div id="google_translate_element" aria-hidden="true"></div>
<script is:inline>
  (function(){
    var loaded = false;
    window.hrGTInit = function(){
      new google.translate.TranslateElement({pageLanguage:'en', includedLanguages:'en,zh-CN,es,ar,pt,tr', autoDisplay:false}, 'google_translate_element');
    };
    function loadGT(after){
      if(loaded){ after && after(); return; }
      loaded = true;
      var s = document.createElement('script');
      s.src = 'https://translate.google.com/translate_a/element.js?cb=hrGTInit';
      s.async = true; s.defer = true;
      document.body.appendChild(s);
      var t = 0;
      (function poll(){
        if(document.querySelector('.goog-te-combo')){ after && after(); }
        else if(t++ < 40){ setTimeout(poll, 150); }
      })();
    }
    window.hrSetLang = function(code, label){
      loadGT(function(){
        var combo = document.querySelector('.goog-te-combo');
        if(combo){
          combo.value = (code === 'en' ? '' : code);
          combo.dispatchEvent(new Event('change'));
          var cur = document.querySelector('.lang-cur');
          if(cur && label){ cur.textContent = label; }
        }
      });
    };
  })();
</script>

<style>
  .hdr { position: sticky; top: 0; z-index: 100; background: rgba(255,255,255,.9); backdrop-filter: saturate(140%) blur(14px); border-bottom: 1px solid var(--line); }
  .hdr-inner { display: flex; align-items: center; gap: 20px; height: 74px; }

  .brand { display: flex; align-items: center; gap: 11px; flex-shrink: 0; }
  .brand-mark svg { width: 38px; height: 38px; border-radius: 11px; box-shadow: var(--sh-sm); }
  .brand-name { font-family: var(--display); font-weight: 800; font-size: 1.34rem; letter-spacing: -0.03em; color: var(--ink); }
  .brand-name .hr { color: var(--brand); }

  .nav { display: flex; align-items: center; gap: 2px; margin-left: 6px; }
  .nav-link { font-family: var(--sans); font-weight: 500; font-size: 0.95rem; color: var(--ink-2); background: none; border: none; cursor: pointer; padding: 9px 12px; border-radius: var(--r-sm); display: inline-flex; align-items: center; gap: 5px; transition: color .15s, background .15s; line-height: 1; }
  .nav-link:hover { color: var(--brand); background: var(--brand-soft); }
  .chev { width: 12px; height: 12px; opacity: .65; transition: transform .2s; }

  .nav-item { position: relative; }
  .dropdown { position: absolute; top: calc(100% + 10px); left: 0; background: #fff; border: 1px solid var(--line); border-radius: var(--r-md); box-shadow: var(--sh-lg); padding: 8px; min-width: 224px; opacity: 0; visibility: hidden; transform: translateY(8px); transition: opacity .18s, transform .18s, visibility .18s; z-index: 50; }
  .nav-item:hover .dropdown, .nav-item:focus-within .dropdown { opacity: 1; visibility: visible; transform: translateY(0); }
  .nav-item:hover .chev { transform: rotate(180deg); }
  .dropdown::before { content: ''; position: absolute; top: -10px; left: 0; right: 0; height: 10px; }
  .dropdown a { display: flex; align-items: center; gap: 11px; padding: 10px 13px; border-radius: var(--r-sm); font-size: 0.92rem; font-weight: 500; color: var(--ink-2); transition: background .14s, color .14s; cursor: pointer; }
  .dropdown a:hover { background: var(--bg-2); color: var(--brand); }
  .dd-all { margin-top: 4px; border-top: 1px solid var(--line); padding-top: 12px !important; color: var(--brand) !important; font-weight: 600 !important; }
  .dropdown-wide { min-width: 244px; }
  .dropdown-right { left: auto; right: 0; }
  .mp-ico { width: 24px; height: 24px; border-radius: 6px; color: #fff; font-weight: 700; font-size: 0.82rem; display: grid; place-items: center; flex-shrink: 0; font-family: var(--display); }

  .hdr-utils { display: flex; align-items: center; gap: 8px; margin-left: auto; }
  .util-btn { display: inline-flex; align-items: center; gap: 6px; background: none; border: 1px solid transparent; cursor: pointer; padding: 8px 11px; border-radius: var(--r-sm); color: var(--ink-2); font-family: var(--sans); font-weight: 600; font-size: 0.88rem; transition: background .15s, color .15s; }
  .util-btn:hover { background: var(--bg-2); color: var(--brand); }
  .cta-btn { padding: 11px 20px; font-size: 0.92rem; }

  .burger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 8px; }
  .burger span { width: 24px; height: 2px; background: var(--ink); border-radius: 2px; transition: .2s; }
  .mnav { display: none; flex-direction: column; padding: 8px 20px 16px; border-top: 1px solid var(--line); background: #fff; }
  .mnav a { padding: 13px 8px; font-weight: 600; color: var(--ink-2); border-bottom: 1px solid var(--line-soft); }
  .mnav a:hover { color: var(--brand); }
  .mnav-cta { color: var(--accent-dark) !important; }

  @media (max-width: 1080px) {
    .nav, .hdr-utils { display: none; }
    .burger { display: flex; margin-left: auto; }
    body.mnav-open .mnav { display: flex; }
  }

  /* Hide Google Translate default UI; keep functionality */
  #google_translate_element { display: none; }
  .goog-te-banner-frame, .skiptranslate { display: none !important; }
  body { top: 0 !important; }
  .goog-text-highlight { background: none !important; box-shadow: none !important; }
</style>
