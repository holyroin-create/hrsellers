---
import Base from '../../layouts/Base.astro';
import { resourceCategories, resourceTools, toolsByCat } from '../../data/resources.mjs';

const ICONS = {
  search: '<svg viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="m17 17 4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>',
  refund: '<svg viewBox="0 0 24 24" fill="none"><path d="M3 12a9 9 0 1 0 3-6.7M3 4v4h4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 8v4l2.5 1.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  tag: '<svg viewBox="0 0 24 24" fill="none"><path d="M3 12V5a2 2 0 0 1 2-2h7l9 9-9 9-9-9Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><circle cx="8" cy="8" r="1.6" fill="currentColor"/></svg>',
  calc: '<svg viewBox="0 0 24 24" fill="none"><rect x="5" y="3" width="14" height="18" rx="2" stroke="currentColor" stroke-width="2"/><path d="M8 7h8M8 11h2M12 11h2M16 11v6M8 15h2M8 19h2M12 15h2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>',
  box: '<svg viewBox="0 0 24 24" fill="none"><path d="M3 8l9-5 9 5v8l-9 5-9-5V8Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M3 8l9 5 9-5M12 13v8" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>',
};
const featured = resourceTools.filter(t => t.reviewed && t.tag).slice(0, 3);
---
<Base title="Resources — The Seller Tool Directory" description="Every tool we recommend for marketplace sellers, organized by category: research, reimbursement, repricing, accounting, and operations.">
  <!-- hero -->
  <section class="page-hero">
    <div class="container">
      <span class="pill"><span class="dot"></span> Curated &amp; disclosed</span>
      <h1 class="display-xl">The seller tool directory.</h1>
      <p class="lead">Every tool we'd actually recommend, grouped by what it does. Reviewed tools link to our full verdict; the rest are described by function so you can shortlist quickly.</p>
      <div class="hero-disc"><svg viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.3"/><path d="M8 7v4M8 5h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg> Some links are affiliate links. If you subscribe through them we may earn a commission at no extra cost to you.</div>
    </div>
  </section>

  <!-- top picks -->
  <section class="section-sm">
    <div class="container">
      <span class="h-eyebrow">Top picks</span>
      <h2 class="display-md" style="margin:10px 0 28px;">Where most sellers should start</h2>
      <div class="picks">
        {featured.map(t => (
          <div class="pick">
            <span class="pick-tag">{t.tag}</span>
            <div class="pick-head">
              <span class="pick-logo" style={`background:${t.color}`}>{t.name.charAt(0)}</span>
              <div><h3>{t.name}</h3>{t.rating && <span class="pick-rating"><span class="stars" style={`--pct:${(t.rating/5)*100}%`}>★★★★★</span> {t.rating.toFixed(1)}</span>}</div>
            </div>
            <p>{t.desc}</p>
            <div class="pick-actions">
              <a href={t.url || "#"} target="_blank" rel="sponsored noopener" class="btn btn-accent pick-btn">Visit →</a>
              {t.reviewed && <a href={`/reviews/${t.reviewed}/`} class="btn btn-ghost pick-btn">Review</a>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- category jump nav -->
  <section class="catnav-wrap">
    <div class="container">
      <div class="catnav">
        {resourceCategories.map(c => (
          <a href={`#${c.id}`} class="catnav-chip"><span set:html={ICONS[c.icon]} /> {c.name}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- directory by category -->
  {resourceCategories.map(c => {
    const tools = toolsByCat(c.id);
    return (
      <section class="section-sm dir-sec" id={c.id}>
        <div class="container">
          <div class="dir-head">
            <span class="dir-icon" set:html={ICONS[c.icon]} />
            <div><h2 class="display-md">{c.name}</h2><p>{c.desc}</p></div>
          </div>
          <div class="dir-grid">
            {tools.map(t => (
              <div class="dir-card">
                <div class="dc-top">
                  <span class="dc-logo" style={`background:${t.color}`}>{t.name.charAt(0)}</span>
                  {t.tag && <span class="dc-tag">{t.tag}</span>}
                </div>
                <h3>{t.name}</h3>
                {t.rating && <span class="dc-rating"><span class="stars" style={`--pct:${(t.rating/5)*100}%`}>★★★★★</span> {t.rating.toFixed(1)}</span>}
                <p>{t.desc}</p>
                <div class="dc-actions">
                  <a href={t.url || "#"} target="_blank" rel="sponsored noopener" class="btn btn-primary dc-btn">Visit →</a>
                  {t.reviewed
                    ? <a href={`/reviews/${t.reviewed}/`} class="dc-review">Read review →</a>
                    : <span class="dc-soon">Review in progress</span>}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    );
  })}

  <!-- closing disclosure -->
  <section class="section-sm">
    <div class="container-narrow">
      <div class="full-disc">
        <h3>How we choose what to list</h3>
        <p>Tools earn a place here by solving a real problem for operating sellers — not by paying the highest commission. Where we have an affiliate relationship, it's disclosed, and it never changes our rating or whether a tool is included. Reviewed tools have been evaluated against the specific jobs sellers hire them for; others are listed by function while a full review is in progress.</p>
        <a href="/editorial-standards/" class="btn btn-ghost" style="margin-top:6px;">Our editorial standards →</a>
      </div>
    </div>
  </section>

  <style>
    .page-hero { padding: 72px 0 36px; background: radial-gradient(60% 60% at 80% 0%, rgba(14,124,102,.08), transparent 70%); }
    .page-hero h1 { margin: 20px 0 18px; max-width: 16ch; }
    .page-hero .lead { max-width: 58ch; margin-bottom: 22px; }
    .hero-disc { display: inline-flex; align-items: center; gap: 9px; font-size: 0.86rem; color: #8a6314; background: var(--gold-soft); border: 1px solid #F0E2C8; padding: 10px 16px; border-radius: 100px; }
    .hero-disc svg { width: 16px; height: 16px; flex-shrink: 0; }

    .picks { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .pick { background: #fff; border: 1px solid var(--line); border-radius: var(--r-lg); padding: 26px; position: relative; box-shadow: var(--sh-sm); display: flex; flex-direction: column; }
    .pick-tag { position: absolute; top: -12px; left: 24px; background: var(--brand); color: #fff; font-size: 0.72rem; font-weight: 700; padding: 5px 14px; border-radius: 100px; }
    .pick-head { display: flex; align-items: center; gap: 13px; margin-bottom: 14px; }
    .pick-logo { width: 48px; height: 48px; border-radius: 12px; color: #fff; font-family: var(--display); font-weight: 800; font-size: 1.4rem; display: grid; place-items: center; }
    .pick-head h3 { font-size: 1.2rem; }
    .pick-rating { font-size: 0.85rem; color: var(--ink-2); font-weight: 600; display: flex; align-items: center; gap: 6px; }
    .stars { position: relative; font-size: 0.95rem; letter-spacing: 1px; color: var(--bg-3); }
    .stars::before { content: '★★★★★'; position: absolute; left: 0; top: 0; width: var(--pct); overflow: hidden; color: var(--gold); white-space: nowrap; }
    .pick p { color: var(--ink-2); font-size: 0.93rem; flex-grow: 1; margin-bottom: 18px; }
    .pick-actions { display: flex; gap: 10px; }
    .pick-btn { padding: 11px 18px; font-size: 0.9rem; }

    .catnav-wrap { position: sticky; top: 74px; z-index: 40; background: rgba(255,255,255,.9); backdrop-filter: blur(10px); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); padding: 12px 0; }
    .catnav { display: flex; gap: 10px; overflow-x: auto; }
    .catnav-chip { display: inline-flex; align-items: center; gap: 8px; white-space: nowrap; font-size: 0.88rem; font-weight: 600; color: var(--ink-2); background: var(--bg-2); border: 1px solid var(--line); padding: 9px 15px; border-radius: 100px; transition: background .15s, color .15s, border-color .15s; }
    .catnav-chip svg { width: 16px; height: 16px; }
    .catnav-chip:hover { background: var(--brand-soft); color: var(--brand); border-color: var(--brand-soft2); }

    .dir-sec { scroll-margin-top: 140px; }
    .dir-sec:nth-child(even) { background: var(--bg-2); }
    .dir-head { display: flex; align-items: center; gap: 16px; margin-bottom: 28px; }
    .dir-icon { width: 50px; height: 50px; border-radius: 13px; background: var(--brand-soft); color: var(--brand); display: grid; place-items: center; flex-shrink: 0; }
    .dir-icon svg { width: 26px; height: 26px; }
    .dir-head p { color: var(--ink-3); font-size: 0.95rem; margin-top: 3px; }

    .dir-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
    .dir-card { background: #fff; border: 1px solid var(--line); border-radius: var(--r-lg); padding: 24px; display: flex; flex-direction: column; transition: transform .16s, box-shadow .16s; }
    .dir-card:hover { transform: translateY(-3px); box-shadow: var(--sh-md); }
    .dc-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
    .dc-logo { width: 44px; height: 44px; border-radius: 11px; color: #fff; font-family: var(--display); font-weight: 800; font-size: 1.3rem; display: grid; place-items: center; }
    .dc-tag { font-size: 0.72rem; font-weight: 700; color: var(--brand-dark); background: var(--brand-soft); padding: 4px 11px; border-radius: 100px; }
    .dir-card h3 { font-size: 1.18rem; margin-bottom: 6px; }
    .dc-rating { font-size: 0.84rem; color: var(--ink-2); font-weight: 600; display: inline-flex; align-items: center; gap: 6px; margin-bottom: 10px; }
    .dir-card p { color: var(--ink-3); font-size: 0.92rem; line-height: 1.55; flex-grow: 1; margin-bottom: 18px; }
    .dc-actions { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
    .dc-btn { padding: 10px 18px; font-size: 0.88rem; }
    .dc-review { font-size: 0.85rem; font-weight: 600; color: var(--brand); }
    .dc-soon { font-size: 0.78rem; color: var(--ink-3); font-style: italic; }

    .full-disc { background: var(--bg-2); border: 1px solid var(--line); border-radius: var(--r-lg); padding: 30px; }
    .full-disc h3 { font-size: 1.3rem; margin-bottom: 12px; }
    .full-disc p { color: var(--ink-2); line-height: 1.65; }

    @media (max-width: 980px) { .picks, .dir-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 640px) { .picks, .dir-grid { grid-template-columns: 1fr; } }
  </style>
</Base>
