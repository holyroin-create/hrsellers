---
import Base from '../../layouts/Base.astro';
import { guideCategories, guidesByCategory, getGuideCategory } from '../../data/guides.mjs';

export function getStaticPaths() {
  return guideCategories.map(c => ({ params: { category: c.id }, props: { cat: c } }));
}
const { cat } = Astro.props;
const list = guidesByCategory(cat.id);

const ICONS = {
  refund: '<svg viewBox="0 0 24 24" fill="none"><path d="M3 12a9 9 0 1 0 3-6.7M3 4v4h4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 8v4l2.5 1.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  truck: '<svg viewBox="0 0 24 24" fill="none"><path d="M2 7h11v9H2zM13 10h4l3 3v3h-7z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><circle cx="6" cy="18" r="2" stroke="currentColor" stroke-width="2"/><circle cx="17" cy="18" r="2" stroke="currentColor" stroke-width="2"/></svg>',
  rocket: '<svg viewBox="0 0 24 24" fill="none"><path d="M12 3c3 1 5 4 5 8l-2 3H9l-2-3c0-4 2-7 5-8Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><circle cx="12" cy="9" r="1.6" fill="currentColor"/><path d="M9 17c-1 1-1.5 3-1.5 4 1 0 3-.5 4-1.5M15 17c1 1 1.5 3 1.5 4-1 0-3-.5-4-1.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  chart: '<svg viewBox="0 0 24 24" fill="none"><path d="M4 20V4M4 20h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M8 16l3-4 3 2 4-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  shield: '<svg viewBox="0 0 24 24" fill="none"><path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>',
};
---
<Base title={`${cat.name} Guides`} description={cat.desc}>
  <section class="cat-hero" style={`--c:${cat.color};--cs:${cat.soft}`}>
    <div class="container">
      <a href="/guides/" class="back">← All guides</a>
      <div class="cat-hero-id">
        <span class="cat-hero-icon" style={`background:${cat.color}`} set:html={ICONS[cat.icon]} />
        <div>
          <h1 class="display-lg">{cat.name}</h1>
          <p class="lead">{cat.desc}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-sm">
    <div class="container">
      {list.length > 0 ? (
        <div class="list">
          {list.map(g => (
            <a href={`/guides/${cat.id}/${g.slug}/`} class="list-item">
              <div class="li-body">
                <h2>{g.title}</h2>
                <p>{g.excerpt}</p>
                <div class="li-meta"><span>{g.time} read</span><span>·</span><span>Updated {g.updated}</span></div>
              </div>
              <svg class="li-arr" viewBox="0 0 20 20" fill="none"><path d="M5 10h10M10 5l5 5-5 5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty">
          <h2>Guides in progress</h2>
          <p>We're writing in-depth guides for this category. In the meantime, explore our other playbooks.</p>
          <a href="/guides/" class="btn btn-primary">Browse all guides →</a>
        </div>
      )}
    </div>
  </section>

  <style>
    .cat-hero { background: var(--cs); padding: 36px 0 48px; }
    .back { font-size: 0.9rem; font-weight: 600; color: var(--c); }
    .cat-hero-id { display: flex; align-items: center; gap: 20px; margin-top: 22px; }
    .cat-hero-icon { width: 66px; height: 66px; border-radius: 16px; color: #fff; display: grid; place-items: center; box-shadow: var(--sh-md); flex-shrink: 0; }
    .cat-hero-icon svg { width: 32px; height: 32px; }
    .cat-hero-id .lead { max-width: 56ch; color: var(--ink-2); margin-top: 4px; }

    .list { display: flex; flex-direction: column; gap: 16px; max-width: 860px; }
    .list-item { display: flex; align-items: center; gap: 24px; background: #fff; border: 1px solid var(--line); border-radius: var(--r-lg); padding: 28px; transition: transform .16s, box-shadow .16s, border-color .16s; }
    .list-item:hover { transform: translateY(-3px); box-shadow: var(--sh-md); border-color: var(--c); }
    .li-body { flex-grow: 1; }
    .li-body h2 { font-size: 1.4rem; margin-bottom: 8px; }
    .li-body p { color: var(--ink-2); margin-bottom: 12px; }
    .li-meta { display: flex; gap: 10px; font-size: 0.84rem; color: var(--ink-3); }
    .li-arr { width: 24px; height: 24px; color: var(--c); flex-shrink: 0; transition: transform .16s; }
    .list-item:hover .li-arr { transform: translateX(4px); }

    .empty { text-align: center; max-width: 480px; margin: 40px auto; }
    .empty h2 { font-size: 1.6rem; margin-bottom: 12px; }
    .empty p { color: var(--ink-2); margin-bottom: 24px; }

    @media (max-width: 620px) { .list-item { flex-direction: column; align-items: flex-start; gap: 16px; } }
  </style>
</Base>
