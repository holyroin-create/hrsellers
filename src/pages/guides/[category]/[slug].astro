---
import Base from '../../../layouts/Base.astro';
import { guides, getGuide, getGuideCategory } from '../../../data/guides.mjs';

export function getStaticPaths() {
  return guides.map(g => ({ params: { category: g.category, slug: g.slug }, props: { g } }));
}
const { g } = Astro.props;
const cat = getGuideCategory(g.category);
const related = (g.related || []).map(s => getGuide(s)).filter(Boolean);

const CALLOUT = {
  tip:     { ic: '<path d="M12 3a6 6 0 0 0-4 10.5c.6.6 1 1.4 1 2.5h6c0-1.1.4-1.9 1-2.5A6 6 0 0 0 12 3Z" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linejoin="round"/><path d="M9 19h6M10 22h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>', label: 'Tip' },
  warning: { ic: '<path d="M12 4 2 20h20L12 4Z" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linejoin="round"/><path d="M12 10v4M12 17h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>', label: 'Heads up' },
  info:    { ic: '<circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8" fill="none"/><path d="M12 11v5M12 8h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>', label: 'Note' },
};
---
<Base title={g.title} description={g.excerpt}>
  <article class="article">
    <!-- header -->
    <header class="art-head" style={`--c:${cat.color};--cs:${cat.soft}`}>
      <div class="container-narrow">
        <div class="art-crumbs">
          <a href="/guides/">Guides</a> <span>/</span> <a href={`/guides/${cat.id}/`} style={`color:${cat.color}`}>{cat.name}</a>
        </div>
        <h1>{g.title}</h1>
        <p class="art-excerpt">{g.excerpt}</p>
        <div class="art-meta">
          <span class="art-author"><span class="aa-avatar">HR</span> HRSellers Editorial</span>
          <span class="art-dot">·</span><span>{g.time} read</span>
          <span class="art-dot">·</span><span>Updated {g.updated}</span>
        </div>
      </div>
    </header>

    <!-- body -->
    <div class="container-narrow">
      <div class="art-body">
        {g.blocks.map(b => {
          if (b.type === 'p') return <p>{b.text}</p>;
          if (b.type === 'h2') return <h2>{b.text}</h2>;
          if (b.type === 'callout') {
            const c = CALLOUT[b.variant];
            return (
              <div class={`callout co-${b.variant}`}>
                <span class="co-icon"><svg viewBox="0 0 24 24" fill="none" set:html={c.ic} /></span>
                <div class="co-body"><span class="co-label">{b.title || c.label}</span><p>{b.text}</p></div>
              </div>
            );
          }
          if (b.type === 'steps') return (
            <ol class="steps-list">
              {b.items.map((s) => (
                <li><span class="sl-num" style={`background:${cat.color}`}></span><div><strong>{s.title}</strong><p>{s.text}</p></div></li>
              ))}
            </ol>
          );
          if (b.type === 'checklist') return (
            <ul class="checklist">
              {b.items.map(it => <li><span class="cl-tick" style={`color:${cat.color}`}>✓</span>{it}</li>)}
            </ul>
          );
          if (b.type === 'table') return (
            <figure class="art-table">
              <table>
                <thead><tr>{b.headers.map(h => <th>{h}</th>)}</tr></thead>
                <tbody>{b.rows.map(r => { const cells = Array.isArray(r) ? r : (r.cells || []); return <tr>{cells.map((cell, i) => <td class={i === 0 ? 'td-first' : ''}>{cell}</td>)}</tr>; })}</tbody>
              </table>
              {b.caption && <figcaption>{b.caption}</figcaption>}
            </figure>
          );
          if (b.type === 'flow') return (
            <figure class="art-flow">
              {b.label && <span class="flow-cap">{b.label}</span>}
              <div class="flow-row">
                {b.steps.map((s, i) => (
                  <>
                    <div class="flow-node"><span class="fn-num" style={`background:${cat.color}`}>{i + 1}</span><span class="fn-label">{s}</span></div>
                    {i < b.steps.length - 1 && <svg class="fn-arr" viewBox="0 0 28 14" fill="none"><path d="M2 7h22M19 3l5 4-5 4" stroke="#C2CBD4" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>}
                  </>
                ))}
              </div>
            </figure>
          );
          if (b.type === 'keynum') return (
            <div class="keynum-row">
              {b.items.map(k => <div class="kn-card"><span class="kn-num" style={`color:${cat.color}`}>{k.num}</span><span class="kn-label">{k.label}</span></div>)}
            </div>
          );
          return null;
        })}
      </div>

      <!-- tools used -->
      {g.tools && g.tools.length > 0 && (
        <div class="art-tools">
          <span class="at-label">Tools mentioned</span>
          <div class="at-list">
            {g.tools.map(t => <a href="/reviews/" class="at-chip"><span class="at-dot" style={`background:${cat.color}`}></span>{t}</a>)}
          </div>
        </div>
      )}

      <!-- disclosure -->
      <div class="art-disc">As an affiliate partner, HRSellers may earn a commission if you subscribe to a recommended tool through our links — at no extra cost to you. Our guidance is independent.</div>
    </div>

    <!-- related -->
    {related.length > 0 && (
      <section class="section-sm bg-2" style="margin-top:64px;">
        <div class="container-narrow">
          <h2 class="display-md" style="margin-bottom:22px;">Keep reading</h2>
          <div class="rel-grid">
            {related.map(r => {
              const rc = getGuideCategory(r.category);
              return (
                <a href={`/guides/${r.category}/${r.slug}/`} class="rel-card">
                  <span class="rel-cat" style={`color:${rc.color}`}>{rc.name}</span>
                  <h3>{r.title}</h3>
                  <span class="rel-arr">Read →</span>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}
  </article>

  <style>
    .art-head { background: var(--cs); padding: 44px 0 40px; }
    .art-crumbs { font-size: 0.85rem; font-weight: 600; color: var(--ink-3); margin-bottom: 18px; }
    .art-crumbs a { color: var(--ink-2); }
    .art-head h1 { font-size: clamp(1.9rem, 4vw, 2.9rem); line-height: 1.1; margin-bottom: 16px; }
    .art-excerpt { font-size: 1.15rem; color: var(--ink-2); line-height: 1.55; margin-bottom: 22px; }
    .art-meta { display: flex; align-items: center; gap: 11px; font-size: 0.88rem; color: var(--ink-3); flex-wrap: wrap; }
    .art-author { display: flex; align-items: center; gap: 9px; font-weight: 600; color: var(--ink-2); }
    .aa-avatar { width: 30px; height: 30px; border-radius: 50%; background: linear-gradient(135deg, var(--brand), var(--accent)); color: #fff; font-size: 0.74rem; font-weight: 700; display: grid; place-items: center; }

    .art-body { padding: 48px 0 8px; }
    .art-body > p { font-size: 1.15rem; line-height: 1.75; color: #2a2620; margin-bottom: 22px; }
    .art-body > h2 { font-family: var(--display); font-size: 1.7rem; letter-spacing: -0.02em; margin: 44px 0 16px; padding-top: 8px; }

    .callout { display: flex; gap: 16px; padding: 20px 22px; border-radius: var(--r-md); margin: 28px 0; border: 1px solid; }
    .callout p { margin: 0; font-size: 1rem; line-height: 1.6; }
    .co-icon { flex-shrink: 0; width: 38px; height: 38px; border-radius: 10px; display: grid; place-items: center; }
    .co-icon svg { width: 22px; height: 22px; }
    .co-label { display: block; font-weight: 700; font-size: 0.92rem; margin-bottom: 4px; }
    .co-tip { background: var(--brand-soft); border-color: var(--brand-soft2); }
    .co-tip .co-icon { background: #fff; color: var(--brand); } .co-tip .co-label { color: var(--brand-dark); }
    .co-warning { background: var(--accent-soft); border-color: #FAD4C8; }
    .co-warning .co-icon { background: #fff; color: var(--accent-dark); } .co-warning .co-label { color: var(--accent-dark); }
    .co-info { background: #E6F1FB; border-color: #CBE0F5; }
    .co-info .co-icon { background: #fff; color: #0071DC; } .co-info .co-label { color: #0056A8; }

    .steps-list { list-style: none; counter-reset: step; margin: 28px 0; display: flex; flex-direction: column; gap: 16px; }
    .steps-list li { display: flex; gap: 16px; counter-increment: step; }
    .sl-num { flex-shrink: 0; width: 34px; height: 34px; border-radius: 50%; color: #fff; font-family: var(--display); font-weight: 800; font-size: 0.95rem; display: grid; place-items: center; }
    .sl-num::before { content: counter(step); }
    .steps-list strong { display: block; font-size: 1.08rem; margin-bottom: 3px; color: var(--ink); }
    .steps-list p { margin: 0; color: var(--ink-2); font-size: 0.98rem; line-height: 1.55; }

    .checklist { list-style: none; margin: 24px 0; display: flex; flex-direction: column; gap: 12px; }
    .checklist li { display: flex; gap: 12px; align-items: flex-start; font-size: 1.05rem; color: #2a2620; background: var(--bg-2); border: 1px solid var(--line); border-radius: var(--r-md); padding: 14px 18px; }
    .cl-tick { font-weight: 800; flex-shrink: 0; }

    .art-table { margin: 30px 0; }
    .art-table table { width: 100%; border-collapse: collapse; border: 1px solid var(--line); border-radius: var(--r-md); overflow: hidden; }
    .art-table th, .art-table td { padding: 13px 16px; text-align: left; font-size: 0.95rem; border-bottom: 1px solid var(--line); }
    .art-table thead th { background: var(--ink); color: #fff; font-weight: 600; }
    .art-table tbody tr:nth-child(even) { background: var(--bg-2); }
    .art-table tbody tr:last-child td { border-bottom: none; }
    .art-table .td-first { font-weight: 600; color: var(--ink); }
    .art-table figcaption { font-size: 0.82rem; color: var(--ink-3); margin-top: 10px; line-height: 1.5; }

    .art-flow { margin: 32px 0; background: var(--bg-2); border: 1px solid var(--line); border-radius: var(--r-lg); padding: 28px 24px; }
    .flow-cap { display: block; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--ink-3); margin-bottom: 18px; }
    .flow-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; justify-content: space-between; }
    .flow-node { display: flex; flex-direction: column; align-items: center; gap: 10px; flex: 1; min-width: 92px; }
    .fn-num { width: 36px; height: 36px; border-radius: 50%; color: #fff; font-family: var(--display); font-weight: 800; display: grid; place-items: center; }
    .fn-label { font-size: 0.86rem; font-weight: 600; text-align: center; color: var(--ink); }
    .fn-arr { width: 28px; height: 14px; flex-shrink: 0; }

    .keynum-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin: 30px 0; }
    .kn-card { background: #fff; border: 1px solid var(--line); border-radius: var(--r-md); padding: 22px; text-align: center; }
    .kn-num { font-family: var(--display); font-weight: 800; font-size: 1.9rem; display: block; margin-bottom: 8px; }
    .kn-label { font-size: 0.86rem; color: var(--ink-2); line-height: 1.4; }

    .art-tools { margin: 40px 0 0; padding: 22px 24px; background: var(--bg-2); border: 1px solid var(--line); border-radius: var(--r-md); }
    .at-label { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--ink-3); display: block; margin-bottom: 12px; }
    .at-list { display: flex; gap: 10px; flex-wrap: wrap; }
    .at-chip { display: inline-flex; align-items: center; gap: 9px; background: #fff; border: 1px solid var(--line); border-radius: 100px; padding: 9px 16px; font-weight: 600; font-size: 0.9rem; transition: border-color .15s; }
    .at-chip:hover { border-color: var(--brand); }
    .at-dot { width: 8px; height: 8px; border-radius: 50%; }

    .art-disc { margin: 24px 0 0; font-size: 0.84rem; color: var(--ink-3); line-height: 1.55; padding: 16px 18px; background: var(--gold-soft); border-radius: var(--r-sm); border: 1px solid #F0E2C8; }

    .rel-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
    .rel-card { background: #fff; border: 1px solid var(--line); border-radius: var(--r-lg); padding: 24px; transition: transform .16s, box-shadow .16s; }
    .rel-card:hover { transform: translateY(-3px); box-shadow: var(--sh-md); }
    .rel-cat { font-size: 0.76rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; }
    .rel-card h3 { font-size: 1.15rem; line-height: 1.25; margin: 8px 0 14px; }
    .rel-arr { color: var(--brand); font-weight: 600; font-size: 0.9rem; }

    @media (max-width: 680px) {
      .keynum-row { grid-template-columns: 1fr; }
      .rel-grid { grid-template-columns: 1fr; }
      .flow-row { flex-direction: column; }
      .fn-arr { transform: rotate(90deg); }
    }
  </style>
</Base>
